run/main_scene="res://addons/git_plugin/src/main.tscn"
config/features=PackedStringArray("4.7", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

ApprenticeAutoload="*uid://baurs4cfdmqvf"

[editor_plugins]

enabled=PackedStringArray("res://addons/git_plugin/plugin.cfg", "res://addons/script_comment_menu/plugin.cfg")
